      "target": "comfyui:text_to_image",
      "linkType": "Extends",
      "strength": "Required",
      "description": "图生图扩展文生图能力"
    },
    {
      "source": "comfyui:video_generation",
      "target": "comfyui:text_to_image",
      "linkType": "Prerequisite",
      "strength": "Required",
      "description": "视频生成需要先具备文生图能力"
    },
    {
      "source": "comfyui:upscale",
      "target": "comfyui:text_to_image",
