{
  "@context": "https://schema.org",
  "@type": "Workflow",
  "name": "variation_generation",
  "description": "变体生成工作流 - 同一提示词生成不同变体",
  "version": "1.0.0",
  "category": "batch",
  "steps": [
    {
      "@type": "WorkflowStep",
      "name": "load_model",
      "action": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "v1-5-pruned-emaonly.safetensors"
      },
      "outputs": ["model", "clip", "vae"]
    },
    {
      "@type": "WorkflowStep",
      "name": "encode_positive",
      "action": "CLIPTextEncode",
      "inputs": {
        "text": "${prompt}",
        "clip": { "from": "load_model", "output": "clip" }
      },
      "outputs": ["positive_conditioning"]
    },
    {
      "@type": "WorkflowStep",
      "name": "encode_negative",
      "action": "CLIPTextEncode",
      "inputs": {
        "text": "${negative_prompt}",
        "clip": { "from": "load_model", "output": "clip" }
      },
      "outputs": ["negative_conditioning"]
    },
    {
      "@type": "WorkflowStep",
      "name": "create_latent",
      "action": "EmptyLatentImage",
      "inputs": {
        "width": "${width}",
        "height": "${height}",
        "batch_size": 1
      },
      "outputs": ["latent"]
    },
    {
      "@type": "WorkflowStep",
      "name": "sample_variations",
      "action": "IterativeSampler",
      "inputs": {
        "model": { "from": "load_model", "output": "model" },
        "positive": { "from": "encode_positive", "output": "positive_conditioning" },
        "negative": { "from": "encode_negative", "output": "negative_conditioning" },
        "latent_image": { "from": "create_latent", "output": "latent" },
        "seed_start": "${seed_start}",
        "seed_increment": "${seed_increment}",
        "num_variations": "${num_variations}",
        "steps": "${steps}",
        "cfg": "${cfg}",
        "sampler_name": "euler"
      },
      "outputs": ["variation_samples"]
    },
    {
      "@type": "WorkflowStep",
      "name": "decode",
      "action": "VAEDecode",
      "inputs": {
        "samples": { "from": "sample_variations", "output": "variation_samples" },
        "vae": { "from": "load_model", "output": "vae" }
      },
      "outputs": ["images"]
    },
    {
      "@type": "WorkflowStep",
      "name": "save",
      "action": "SaveImage",
      "inputs": {
        "images": { "from": "decode", "output": "images" },
        "filename_prefix": "Variation"
      },
      "outputs": ["saved_paths"]
    }
  ],
  "parameters": {
    "prompt": { "type": "string", "default": "creative variations", "required": true },
    "negative_prompt": { "type": "string", "default": "blurry" },
    "width": { "type": "integer", "default": 512 },
    "height": { "type": "integer", "default": 512 },
    "num_variations": { "type": "integer", "default": 4 },
    "seed_start": { "type": "integer", "default": 100 },
    "seed_increment": { "type": "integer", "default": 1 },
    "steps": { "type": "integer", "default": 20 },
    "cfg": { "type": "float", "default": 7.0 }
  }
}