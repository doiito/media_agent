{
  "@context": "https://schema.org",
  "@type": "Workflow",
  "name": "inpainting",
  "description": "图片修复工作流 - 局部重绘",
  "version": "1.0.0",
  "category": "edit",
  "steps": [
    {
      "@type": "WorkflowStep",
      "name": "load_model",
      "action": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "v1-5-pruned-emaonly.safetensors"
      },
      "outputs": ["model", "clip", "vae"]
    },
    {
      "@type": "WorkflowStep",
      "name": "load_image",
      "action": "LoadImage",
      "inputs": {
        "image": "${input_image_path}"
      },
      "outputs": ["pixels"]
    },
    {
      "@type": "WorkflowStep",
      "name": "load_mask",
      "action": "LoadImage",
      "inputs": {
        "image": "${mask_path}"
      },
      "outputs": ["mask"]
    },
    {
      "@type": "WorkflowStep",
      "name": "encode_image",
      "action": "VAEEncode",
      "inputs": {
        "pixels": { "from": "load_image", "output": "pixels" },
        "vae": { "from": "load_model", "output": "vae" }
      },
      "outputs": ["latent"]
    },
    {
      "@type": "WorkflowStep",
      "name": "encode_positive",
      "action": "CLIPTextEncode",
      "inputs": {
        "text": "${prompt}",
        "clip": { "from": "load_model", "output": "clip" }
      },
      "outputs": ["positive_conditioning"]
    },
    {
      "@type": "WorkflowStep",
      "name": "encode_negative",
      "action": "CLIPTextEncode",
      "inputs": {
        "text": "${negative_prompt}",
        "clip": { "from": "load_model", "output": "clip" }
      },
      "outputs": ["negative_conditioning"]
    },
    {
      "@type": "WorkflowStep",
      "name": "sample",
      "action": "KSampler",
      "inputs": {
        "model": { "from": "load_model", "output": "model" },
        "positive": { "from": "encode_positive", "output": "positive_conditioning" },
        "negative": { "from": "encode_negative", "output": "negative_conditioning" },
        "latent_image": { "from": "encode_image", "output": "latent" },
        "seed": "${seed}",
        "steps": "${steps}",
        "cfg": "${cfg}",
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": "${denoise}"
      },
      "outputs": ["samples"]
    },
    {
      "@type": "WorkflowStep",
      "name": "decode",
      "action": "VAEDecode",
      "inputs": {
        "samples": { "from": "sample", "output": "samples" },
        "vae": { "from": "load_model", "output": "vae" }
      },
      "outputs": ["image"]
    },
    {
      "@type": "WorkflowStep",
      "name": "save",
      "action": "SaveImage",
      "inputs": {
        "images": { "from": "decode", "output": "image" },
        "filename_prefix": "Inpaint"
      },
      "outputs": ["saved_path"]
    }
  ],
  "parameters": {
    "input_image_path": { "type": "string", "required": true },
    "mask_path": { "type": "string", "required": true },
    "prompt": { "type": "string", "default": "fill the masked area", "required": true },
    "negative_prompt": { "type": "string", "default": "blurry" },
    "steps": { "type": "integer", "default": 20 },
    "cfg": { "type": "float", "default": 7.0 },
    "denoise": { "type": "float", "default": 0.85 },
    "seed": { "type": "integer", "default": -1 }
  }
}