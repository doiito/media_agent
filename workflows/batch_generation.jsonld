{
  "@context": "https://schema.org",
  "@type": "Workflow",
  "name": "batch_generation",
  "description": "批量图片生成工作流 - 多张图片并行生成",
  "version": "1.0.0",
  "category": "batch",
  "steps": [
    {
      "@type": "WorkflowStep",
      "name": "load_model",
      "action": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "v1-5-pruned-emaonly.safetensors"
      },
      "outputs": ["model", "clip", "vae"]
    },
    {
      "@type": "WorkflowStep",
      "name": "encode_positive",
      "action": "CLIPTextEncode",
      "inputs": {
        "text": "${prompt}",
        "clip": { "from": "load_model", "output": "clip" }
      },
      "outputs": ["positive_conditioning"]
    },
    {
      "@type": "WorkflowStep",
      "name": "encode_negative",
      "action": "CLIPTextEncode",
      "inputs": {
        "text": "${negative_prompt}",
        "clip": { "from": "load_model", "output": "clip" }
      },
      "outputs": ["negative_conditioning"]
    },
    {
      "@type": "WorkflowStep",
      "name": "create_latent",
      "action": "EmptyLatentImage",
      "inputs": {
        "width": "${width}",
        "height": "${height}",
        "batch_size": "${batch_size}"
      },
      "outputs": ["latent"]
    },
    {
      "@type": "WorkflowStep",
      "name": "sample",
      "action": "KSampler",
      "inputs": {
        "model": { "from": "load_model", "output": "model" },
        "positive": { "from": "encode_positive", "output": "positive_conditioning" },
        "negative": { "from": "encode_negative", "output": "negative_conditioning" },
        "latent_image": { "from": "create_latent", "output": "latent" },
        "seed": "${seed}",
        "steps": "${steps}",
        "cfg": "${cfg}",
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1.0
      },
      "outputs": ["samples"]
    },
    {
      "@type": "WorkflowStep",
      "name": "decode",
      "action": "VAEDecode",
      "inputs": {
        "samples": { "from": "sample", "output": "samples" },
        "vae": { "from": "load_model", "output": "vae" }
      },
      "outputs": ["images"]
    },
    {
      "@type": "WorkflowStep",
      "name": "save_batch",
      "action": "SaveImage",
      "inputs": {
        "images": { "from": "decode", "output": "images" },
        "filename_prefix": "Batch"
      },
      "outputs": ["saved_paths"]
    }
  ],
  "parameters": {
    "prompt": { "type": "string", "default": "multiple variations", "required": true },
    "negative_prompt": { "type": "string", "default": "blurry" },
    "width": { "type": "integer", "default": 512 },
    "height": { "type": "integer", "default": 512 },
    "batch_size": { "type": "integer", "default": 4, "min": 1, "max": 16 },
    "steps": { "type": "integer", "default": 20 },
    "cfg": { "type": "float", "default": 7.0 },
    "seed": { "type": "integer", "default": -1 }
  }
}